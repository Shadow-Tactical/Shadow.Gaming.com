<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Website</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#1b1b1b;
            color:white;
        }

        header{
            background:#222;
            padding:20px;
            text-align:center;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin:0 15px;
        }

        .hero{
            height:70vh;
            display:flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            text-align:center;
            background:linear-gradient(135deg,#0077ff,#00bfff);
        }

        .hero h1{
            font-size:3rem;
            margin-bottom:15px;
        }

        .hero p{
            font-size:1.2rem;
            margin-bottom:25px;
        }

        button{
            padding:12px 25px;
            border:none;
            border-radius:8px;
            background:white;
            color:#0077ff;
            font-size:16px;
            cursor:pointer;
        }

        section{
            padding:60px 20px;
            max-width:900px;
            margin:auto;
            text-align:center;
        }

        footer{
            background:#222;
            padding:20px;
            text-align:center;
        }
    </style>
</head>
<body>

<header>
    <h2>My Website</h2>
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </nav>
</header>

<div class="hero">
    <h1>Welcome!</h1>
    <p>This is a simple website made with HTML and CSS.</p>
    <button onclick="sayHello()">Click Me</button>
</div>

<section>
    <h2>About</h2>
    <p>
        Replace this text with anything you want. This section is great
        for describing yourself, your business, or a project.
    </p>
</section>

<footer>
    © 2026 My Website
</footer>

<script>
function sayHello(){
    alert("Thanks for visiting!");
}
</script>

</body>
</html>
